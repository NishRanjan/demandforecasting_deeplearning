# ─────────────────────────────────────────────────────────────────────────────
# Demand Forecasting Pipeline — Environment Variables Template
# Copy this file to .env and fill in your values.
# On Databricks: set these as cluster environment variables or use secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Azure Blob Storage URL for the input dataset (used in Databricks mode)
BLOB_URL=https://<storage-account>.blob.core.windows.net/<container>/<path-to-file>.csv

# MLflow experiment path (Databricks workspace)
MLFLOW_EXPERIMENT_NAME=/Users/<your-email>/demand_forecast

# Databricks workspace output directory for saving CSVs
DATABRICKS_OUTPUT_DIR=/Workspace/Users/<your-email>/india_fc_experiments/data
